{
  "hosting": {
    "public": "dist/fichas3.5",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": [
    {
      "database": "fichas-rol",
      "rules": "firestore.fichas-rol.rules",
      "indexes": "firestore.fichas-rol.indexes.json"
    }
  ],
  "database": {
    "rules": "database.rules.json"
  }
}
